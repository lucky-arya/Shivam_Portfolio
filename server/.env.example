# Email Configuration
# Replace these with your actual email credentials

# Your Gmail address (or other email service)
EMAIL_USER=your.email@gmail.com

# Your Gmail App Password (not your regular password)
# For Gmail: Go to Google Account → Security → 2-Step Verification → App passwords
# Generate a new app password and use it here
EMAIL_PASS=your-app-specific-password

# Server Port (optional, defaults to 3001)
PORT=3001
